rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'mh.umateus@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidSchoolEvent(data) {
      return data.keys().hasOnly(['title', 'description', 'date', 'authorId', 'createdAt', 'isPublic'])
        && data.keys().hasAll(['title', 'date', 'authorId', 'createdAt', 'isPublic'])
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 100
        && (data.keys().hasAny(['description']) ? (data.description is string && data.description.size() <= 500) : true)
        && data.date is timestamp
        && data.authorId == request.auth.uid
        && data.createdAt is timestamp
        && data.isPublic is bool
        && data.isPublic == true;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /events/{eventId} {
      allow read: if resource.data.isPublic == true;
      allow create: if isAdmin()
        && isValidId(eventId)
        && isValidSchoolEvent(request.resource.data);
      allow update: if isAdmin()
        && isValidId(eventId)
        && isValidSchoolEvent(request.resource.data)
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin() && isValidId(eventId);
    }
  }
}
