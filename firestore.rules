rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\-]+$');
    }

    function isValidPriority(priority) {
      return priority in ['normal', 'importante', 'urgente'];
    }

    function isValidSchoolEvent(data) {
      return data.keys().hasAll(['title', 'date', 'authorId', 'createdAt', 'isPublic']) &&
      data.keys().hasOnly([
        'title', 'description', 'category', 'date', 'authorId', 'createdAt', 'updatedAt', 'updatedBy',
        'isPublic', 'isPinned', 'priority', 'deletedAt', 'deletedBy', 'duplicatedFrom'
      ]) &&
      data.title is string &&
      data.title.size() > 0 &&
      data.title.size() <= 100 &&
      (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
      (!('category' in data) || (data.category is string && data.category.size() <= 50)) &&
      data.date is timestamp &&
      data.authorId == request.auth.uid &&
      data.createdAt is timestamp &&
      data.createdAt <= request.time &&
      data.createdAt >= request.time - duration.value(10, 'm') &&
      (!('updatedAt' in data) || data.updatedAt is timestamp) &&
      (!('updatedBy' in data) || data.updatedBy is string) &&
      data.isPublic is bool &&
      (!('isPinned' in data) || data.isPinned is bool) &&
      (!('priority' in data) || isValidPriority(data.priority)) &&
      (!('deletedAt' in data) || data.deletedAt is timestamp) &&
      (!('deletedBy' in data) || data.deletedBy is string) &&
      (!('duplicatedFrom' in data) || data.duplicatedFrom is string);
    }

    function changedEventKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isValidEventPatch(data) {
      return changedEventKeys().hasOnly([
        'title', 'description', 'category', 'date', 'updatedAt', 'updatedBy',
        'isPublic', 'isPinned', 'priority', 'deletedAt', 'deletedBy', 'duplicatedFrom'
      ]) &&
      !changedEventKeys().hasAny(['authorId', 'createdAt']) &&
      (!('title' in data) || (data.title is string && data.title.size() > 0 && data.title.size() <= 100)) &&
      (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
      (!('category' in data) || (data.category is string && data.category.size() <= 50)) &&
      (!('date' in data) || data.date is timestamp) &&
      (!('updatedAt' in data) || (data.updatedAt is timestamp && data.updatedAt <= request.time && data.updatedAt >= request.time - duration.value(10, 'm'))) &&
      (!('updatedBy' in data) || data.updatedBy == request.auth.uid) &&
      (!('isPublic' in data) || data.isPublic is bool) &&
      (!('isPinned' in data) || data.isPinned is bool) &&
      (!('priority' in data) || isValidPriority(data.priority)) &&
      (!('deletedAt' in data) || (data.deletedAt is timestamp && data.deletedAt <= request.time && data.deletedAt >= request.time - duration.value(10, 'm'))) &&
      (!('deletedBy' in data) || data.deletedBy == request.auth.uid) &&
      (!('duplicatedFrom' in data) || data.duplicatedFrom is string);
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['eventId', 'action', 'actorId', 'at', 'title']) &&
      data.keys().hasOnly(['eventId', 'action', 'actorId', 'at', 'title', 'snapshot']) &&
      data.eventId is string &&
      data.eventId.size() <= 128 &&
      data.action in ['created', 'updated', 'duplicated', 'deleted', 'restored', 'permanently_deleted'] &&
      data.actorId == request.auth.uid &&
      data.at is timestamp &&
      data.at <= request.time &&
      data.at >= request.time - duration.value(10, 'm') &&
      data.title is string &&
      data.title.size() <= 120;
    }

    function subscriptionOwnerIsValid(data) {
      return !isSignedIn() || !('uid' in data) || data.uid == request.auth.uid;
    }

    function isValidSubscription(data, subscriptionId) {
      return isValidId(subscriptionId) &&
      data.keys().hasAll(['token', 'tokenHash', 'permission', 'createdAt', 'updatedAt']) &&
      data.keys().hasOnly(['token', 'tokenHash', 'uid', 'email', 'userAgent', 'permission', 'createdAt', 'updatedAt']) &&
      data.token is string &&
      data.token.size() > 20 &&
      data.token.size() <= 4096 &&
      data.tokenHash == subscriptionId &&
      data.permission == 'granted' &&
      data.createdAt is timestamp &&
      data.createdAt <= request.time &&
      data.createdAt >= request.time - duration.value(10, 'm') &&
      data.updatedAt is timestamp &&
      data.updatedAt <= request.time &&
      data.updatedAt >= request.time - duration.value(10, 'm') &&
      subscriptionOwnerIsValid(data) &&
      (!('uid' in data) || data.uid == null || data.uid is string) &&
      (!('email' in data) || data.email == null || (data.email is string && data.email.size() <= 254)) &&
      (!('userAgent' in data) || (data.userAgent is string && data.userAgent.size() <= 300));
    }

    function isValidSubscriptionUpdate(data, subscriptionId) {
      return isValidSubscription(data, subscriptionId) &&
      data.createdAt == resource.data.createdAt &&
      data.tokenHash == resource.data.tokenHash &&
      data.token == resource.data.token;
    }

    match /events/{eventId} {
      allow read: if isAdmin() || (resource.data.isPublic == true && !('deletedAt' in resource.data));

      allow create: if isAdmin()
        && isValidId(eventId)
        && isValidSchoolEvent(request.resource.data);

      allow update: if isAdmin()
        && isValidId(eventId)
        && isValidEventPatch(request.resource.data);

      allow delete: if isAdmin() && isValidId(eventId);
    }

    match /eventHistory/{historyId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidHistory(request.resource.data);
      allow update, delete: if false;
    }

    match /notificationSubscriptions/{subscriptionId} {
      allow create: if isValidSubscription(request.resource.data, subscriptionId);
      allow update: if isValidSubscriptionUpdate(request.resource.data, subscriptionId);
      allow read, delete: if isAdmin();
    }

    match /notificationLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
